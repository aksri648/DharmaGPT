# ===========================================
# DharmaGPT - Render Deployment Environment
# ===========================================
# Copy these values into Render's Environment Variables tab
# or use render.yaml for automatic setup

# ===========================================
# DATABASE (Auto-configured by Render)
# ===========================================
# DATABASE_URL is auto-set when you link a Render PostgreSQL database
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://placeholder:placeholder@placeholder.render.com:5432/dharmagpt

# ===========================================
# LLM CONFIGURATION
# ===========================================
# Option 1: Local Ollama (for development)
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=

# Option 2: OpenAI API (for production)
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-your-openai-api-key-here

# Option 3: Other OpenAI-compatible API
# LLM_BASE_URL=https://your-api-endpoint.com/v1
# LLM_API_KEY=your-api-key-here

LLM_MODEL=qwen3:8b
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=

# ===========================================
# EMBEDDINGS
# ===========================================
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSIONS=1024

# ===========================================
# VECTOR STORE COLLECTIONS
# ===========================================
PGVECTOR_COLLECTION_GITA=dharma_gita
PGVECTOR_COLLECTION_RAMAYANA=dharma_ramayana
PGVECTOR_COLLECTION_STORIES=dharma_stories

# ===========================================
# RETRIEVAL TUNING
# ===========================================
RETRIEVER_K=5
RETRIEVER_SCORE_THRESHOLD=0.5
HYBRID_BM25_K=10
RRF_K=60

# ===========================================
# GRAPH NODE CONFIG
# ===========================================
MAX_SELECTED_VERSES=3
MAX_SELECTED_STORIES=2
GRAPH_RECURSION_LIMIT=25

# ===========================================
# API CONFIGURATION
# ===========================================
API_PREFIX=/api/v1
CORS_ORIGINS=["*"]
CHAT_MESSAGE_MAX_LENGTH=2000

# ===========================================
# APP CONFIGURATION
# ===========================================
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info

# ===========================================
# FRONTEND (Vite)
# ===========================================
# For production, set this to your backend API URL
# VITE_API_URL=https://dharmagpt-api.onrender.com
VITE_API_URL=/api
