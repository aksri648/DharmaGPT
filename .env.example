# ===========================================
# DharmaGPT - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# ===========================================
# DATABASE
# ===========================================
# For Render: Use the DATABASE_URL provided by Render PostgreSQL
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=

# ===========================================
# LLM CONFIGURATION
# ===========================================
# For Render: Use a cloud LLM API (OpenAI, Anthropic, etc.)
# For Local: Use Ollama at http://localhost:11434/v1
LLM_MODEL=qwen3:8b
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=

# ===========================================
# EMBEDDINGS
# ===========================================
# Uses OpenAI-compatible API (same as LLM)
# For OpenAI: text-embedding-3-small (1536 dims)
# For Ollama: nomic-embed-text (768 dims)
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ===========================================
# VECTOR STORE COLLECTIONS
# ===========================================
PGVECTOR_COLLECTION_GITA=dharma_gita
PGVECTOR_COLLECTION_RAMAYANA=dharma_ramayana
PGVECTOR_COLLECTION_STORIES=dharma_stories

# ===========================================
# RETRIEVAL TUNING
# ===========================================
RETRIEVER_K=5
RETRIEVER_SCORE_THRESHOLD=0.5
HYBRID_BM25_K=10
RRF_K=60

# ===========================================
# GRAPH NODE CONFIG
# ===========================================
MAX_SELECTED_VERSES=3
MAX_SELECTED_STORIES=2
GRAPH_RECURSION_LIMIT=25

# ===========================================
# API CONFIGURATION
# ===========================================
API_PREFIX=/api/v1
CORS_ORIGINS=["*"]
CHAT_MESSAGE_MAX_LENGTH=2000

# ===========================================
# APP CONFIGURATION
# ===========================================
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info

# ===========================================
# FRONTEND (Vite)
# ===========================================
# For production: Set to your backend API URL
# For development: Leave as /api (uses Vite proxy)
VITE_API_URL=/api
