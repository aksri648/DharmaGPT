# ===========================================
# DharmaGPT - Docker Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# ===========================================
# DATABASE
# ===========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=dharmagpt
DB_PORT=5432

# ===========================================
# LLM CONFIGURATION
# ===========================================
# For local Ollama (default)
LLM_MODEL=qwen3:8b
LLM_BASE_URL=http://host.docker.internal:11434/v1
LLM_API_KEY=

# For OpenAI (uncomment and set)
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-your-key-here
# LLM_MODEL=gpt-4o-mini

# For Azure OpenAI (uncomment and set)
# LLM_BASE_URL=https://your-resource.openai.azure.com/openai/deployments/your-deployment
# LLM_API_KEY=your-azure-key
# LLM_MODEL=gpt-4o-mini

# ===========================================
# EMBEDDINGS
# ===========================================
# Uses OpenAI-compatible API
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ===========================================
# VECTOR STORE COLLECTIONS
# ===========================================
PGVECTOR_COLLECTION_GITA=dharma_gita
PGVECTOR_COLLECTION_RAMAYANA=dharma_ramayana
PGVECTOR_COLLECTION_STORIES=dharma_stories

# ===========================================
# RETRIEVAL TUNING
# ===========================================
RETRIEVER_K=5
RETRIEVER_SCORE_THRESHOLD=0.5
HYBRID_BM25_K=10
RRF_K=60

# ===========================================
# GRAPH NODE CONFIG
# ===========================================
MAX_SELECTED_VERSES=3
MAX_SELECTED_STORIES=2
GRAPH_RECURSION_LIMIT=25

# ===========================================
# API CONFIGURATION
# ===========================================
API_PREFIX=/api/v1
CORS_ORIGINS=["*"]
CHAT_MESSAGE_MAX_LENGTH=2000

# ===========================================
# APP CONFIGURATION
# ===========================================
LOG_LEVEL=info

# ===========================================
# PORTS
# ===========================================
BACKEND_PORT=8000
FRONTEND_PORT=80
